# OpenAI 兼容 API 配置
# 支持 OpenAI、DeepSeek、通义千问、Moonshot 等任意兼容服务
OPENAI_API_KEY=sk-your-api-key-here
OPENAI_BASE_URL=https://api.openai.com/v1
TRANSLATION_MODEL=gpt-4o

# 并发与限速配置
# 根据你的 API 套餐调整，避免触发限速
TRANSLATION_WORKERS=5        # 并发线程数
TRANSLATION_RPM=1000         # 每分钟最大请求数 (RPM)
TRANSLATION_TPM=100000       # 每分钟最大 token 数 (TPM)
TRANSLATION_TIMEOUT=300      # 单次 API 调用超时秒数
